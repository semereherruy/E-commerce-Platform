# Backend API Configuration
# Local development: http://localhost:8000/api/v1
# Production: https://your-backend-api.com/api/v1
NEXT_PUBLIC_API_URL=https://nebi-store-backend-prod.onrender.com

# Optional: Backend hostname for image serving (for Vercel)
# NEXT_PUBLIC_API_HOSTNAME=api.nebistore.com

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_PAYMENT=true

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
